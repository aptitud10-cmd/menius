# ============================================================
# MENIUS SaaS — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ---- Supabase (REQUIRED) ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- App URL (REQUIRED) ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=menius.app

# ---- Stripe Payments (Optional — enables payment links and subscriptions) ----
STRIPE_SECRET_KEY=sk_test_...
# Billing webhook (customer subscriptions): Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...
# Payments webhook (order checkout): Dashboard → Developers → Webhooks
STRIPE_PAYMENTS_WEBHOOK_SECRET=whsec_...
# Connect V2 thin-events webhook: Dashboard → Developers → Webhooks → Connected accounts
# Payload style: Thin · Events: v2.core.account[requirements].updated,
#                               v2.core.account[configuration.recipient].capability_status_updated
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs for subscription plans (create in Stripe Dashboard)
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_ANNUAL=price_...

# ---- WhatsApp Business API (Optional — enables WhatsApp notifications + AI agent) ----
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=menius-verify-token

# ---- AI / Gemini (Optional — enables AI image gen, menu import, WhatsApp AI) ----
GEMINI_API_KEY=your-gemini-api-key

# ---- AI / fal.ai (Optional — enables highest-quality bulk image generation) ----
# When set, bulk regeneration uses Flux Pro Kontext (with style anchor) or Flux Pro v1.1
# Get your key at: https://fal.ai/dashboard/keys
FAL_API_KEY=fal-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Email / Resend (Optional — enables transactional emails) ----
RESEND_API_KEY=re_...

# ---- Error Monitoring / Sentry (Optional — enables error tracking) ----
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_DSN=https://...@sentry.io/...
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=menius-saas

# ---- Rate Limiting / Upstash Redis (Optional — Redis-backed rate limiting) ----
# If not set, falls back to in-memory rate limiting (not suitable for multi-instance)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ---- Admin Panel (Optional — super-admin access to /admin) ----
ADMIN_EMAIL=your-admin@email.com

# ---- Admin debug tools (Optional — shows bulk image regen button for this restaurant) ----
# Set to your test/admin restaurant UUID to enable the admin regeneration feature
NEXT_PUBLIC_ADMIN_REGEN_RESTAURANT_ID=

# ---- Mapbox (Optional — enables reliable live delivery tracking map) ----
# Get your token at: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoiXXXYWJjIiwiYSI6ImNsbHh4eHh4eDAwMDB4eHh4eHh4eCJ9.XXXXXXXXXXXXXXXXX

# ---- Crisp Chat (Optional — enables live chat widget on all pages) ----
# Get your Website ID at: https://app.crisp.chat → Settings → Website → Integration
NEXT_PUBLIC_CRISP_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ---- PostHog Analytics (Optional — enables product analytics) ----
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
